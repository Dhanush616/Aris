{
  "name": "aris",
  "productName": "Aris",
  "author": "Aris Developer",
  "description": "Aris Chess Application",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
